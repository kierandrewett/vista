<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose draws the UI; this theme only governs the window before first frame.
         DayNight parent so the pre-frame background matches the adaptive theme. -->
    <style name="Theme.Vista" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/vista_window_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
